{
  "extends": [
    "development"
  ],
  "hints": {
    "no-inline-styles": "off",
    "typescript-config/consistent-casing": "off",
    "compat-api/css": [
      "default",
      {
        "ignore": [
          "outline-color: oklch(0.75 0.18 180 / 0.5)"
        ]
      }
    ],
    "axe/forms": "off",
    "axe/name-role-value": "off"
  }
}